    "format-icons": ["’ēä", "’ēā", "’ēé", "’ēü", "’ēĆ"]
  },

  // Bluetooth
  "bluetooth": {
    "format-disabled": "",
    "format-off": "",
    "interval": 30,
    "on-click": "blueman-manager",
    "format-no-controller": ""
  },

  // Other
  "user": {
    "format": "{user}",
    "interval": 60,
    "icon": false
  },

  //Idle Inhibator
  "idle_inhibitor": {
    "format": "{icon}",
    "tooltip": true,
    "format-icons": {
      "activated": "’Åü",
      "deactivated": "’ĆŻ"
    },
    "on-click-right": "hyprlock"
  },

  // TRY ADDING escape -> true to see if it uses less GPU
  "custom/cava": {
    "format": "{}",
    "exec": "~/.config/waybar/scripts/cava.sh"
  },

  "custom/playerinfo": {
    "format": "  {}  ",
    "exec": "~/.config/waybar/scripts/playerinfo.sh",
    "interval": 1,
    "escape": true
  },

  "custom/piss": {
    "format": "  {}  ",
    "exec": "~/.config/waybar/scripts/piss.py",
    "escape": true
  },

  "custom/weather": {
    "format": " {}  ",
    "exec": "~/.config/waybar/scripts/weather.py",
    "escape": true,
    "interval": 600 // update every 10 mins
  }
