  // System tray
  "tray": {
    "icon-size": 24,
    "spacing": 8
  },

  // Clock
  "clock": {
    // "timezone": "America/New_York",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format": "¾░źö  {0:%I:%M %p}  ’ü│  {0:%Y-%m-%d}"
  },

  "hyprland/language": {
    "format": "/ K {short}"
  },

  // Network
  "network": {
    "format": "{ifname}",
    "format-wifi": " ’ć½   {ipaddr}/{cidr}  ",
    "format-ethernet": "’Ŗć   ",
    "format-disconnected": " ¾░▓ø  No connection  ",
    "tooltip-format": "’Ŗć  {ifname} via {gwaddri}",
    "tooltip-format-wifi": "’ć½   {essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "’āü  {ifname} ({ipaddr}/{cidr})",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
    "interval": 1,
    "on-click": "nm-connection-editor"
  },

  // Battery
  "battery": {
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": " {icon}   {capacity}%  ",
    "format-charging": " ’ć”  {capacity}%  ",
    "format-plugged": " ’ć”  {capacity}%  ",
